# .gitignore

# ============================================================
# DEPENDENCIES
# ============================================================
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================================
# BUILD OUTPUTS
# ============================================================
dist/
build/
*.exe
*.dmg
*.pkg
*.deb
*.rpm
*.apk
*.app

# ============================================================
# TEMPORARY FILES
# ============================================================
*.tmp
*.temp
*.log
*.cache
*.swp
*.swo
*.swn
*~
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# IDE / EDITOR
# ============================================================
.vscode/
.idea/
*.iml
*.sublime-project
*.sublime-workspace
*.code-workspace
*.code-snippets

# ============================================================
# ENVIRONMENT & CONFIG
# ============================================================
.env
.env.local
.env.*.local
*.local
*.secret
*.key
*.pem
*.crt

# ============================================================
# CACHE
# ============================================================
.cache/
.parcel-cache/
.vite/
.next/
.nuxt/
.svelte-kit/
.eslintcache
.prettiercache
*.tsbuildinfo

# ============================================================
# COVERAGE & TEST
# ============================================================
coverage/
.nyc_output/
*.test.js
*.spec.js
__tests__/

# ============================================================
# DOCUMENTATION
# ============================================================
docs/_build/
docs/api/
*.pdf
*.epub

# ============================================================
# PROJECT SPECIFIC
# ============================================================

# IndexedDB (браузерные кэши)
*.sqlite
*.sqlite3
*.db
*.db-wal
*.db-shm

# ============================================================
# OS SPECIFIC
# ============================================================
# macOS
.AppleDouble
.LSOverride
._*

# Windows
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.appx

# Linux
*.pid
*.socket
*.sock

# ============================================================
# LOGS
# ============================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# ============================================================
# MISC
# ============================================================
*.zip
*.tar.gz
*.rar
*.7z
.DS_Store
.directory
